# ===== Festival AI Map · Backend 환경변수 예시 =====
# 이 파일을 backend/.env 로 복사한 뒤 값을 채우세요.  cp .env.example .env

# --- Database ---
# 로컬 개발(기본): SQLite. 별도 설치 불필요.
DATABASE_URL=sqlite:///./festival.db
# 운영/Supabase 예시:
# DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# --- 공공데이터포털(data.go.kr) 일반 인증키(Decoding) ---
# 대전/울산/부산/보성/괴산/서천/세종/영천/경주/춘천/광양 + 한국관광공사 TourAPI 에 사용
PUBLIC_DATA_API_KEY=

# --- (선택) KOPIS 공연예술통합전산망 키 ---
KOPIS_API_KEY=

# --- (선택) ifac.or.kr 지역축제 키 ---
IFAC_API_KEY=

# --- (선택) YouTube Data API v3 키 — 우측 SNS 패널 실제 영상 검색 ---
YOUTUBE_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- 스케줄러 (하루 1회 자동 수집, KST) ---
SCHEDULE_HOUR=4
SCHEDULE_MINUTE=0
# 앱 시작 시 즉시 1회 수집할지 여부 (첫 실행에 유용)
COLLECT_ON_STARTUP=true

# --- CORS (프론트엔드 origin) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 로컬 시드 엑셀 (문화체육관광부 2026 전국 축제, 키 없이 동작) ---
LOCAL_FESTIVAL_XLSX=data/2026_festivals.xlsx

# --- (선택) 추가 지자체 축제 API 주입 (코드 수정 없이 소스 추가) ---
# EXTRA_SOURCES_JSON=[{"name":"changnyeong","label":"창녕군 행사","url":"https://.../getEvent","fmt":"xml","region_hint":"경상남도","param_style":"std"}]
